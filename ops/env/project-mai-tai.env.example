# Root-owned production environment file for /etc/project-mai-tai/project-mai-tai.env

MAI_TAI_ENVIRONMENT=production
MAI_TAI_LOG_LEVEL=INFO

MAI_TAI_CONTROL_PLANE_HOST=127.0.0.1
MAI_TAI_CONTROL_PLANE_PORT=8100

MAI_TAI_DATABASE_URL=postgresql+psycopg://mai_tai:REPLACE_DB_PASSWORD@localhost:5432/project_mai_tai
MAI_TAI_REDIS_URL=redis://localhost:6379/0
MAI_TAI_REDIS_STREAM_PREFIX=mai_tai

# Optional legacy-side shadow comparison.
MAI_TAI_LEGACY_API_BASE_URL=http://127.0.0.1:8000
MAI_TAI_LEGACY_API_TIMEOUT_SECONDS=3
MAI_TAI_LEGACY_API_CACHE_TTL_SECONDS=5

MAI_TAI_MASSIVE_API_KEY=REPLACE_MASSIVE_API_KEY
MAI_TAI_MARKET_DATA_SNAPSHOT_INTERVAL_SECONDS=5
MAI_TAI_MARKET_DATA_REFERENCE_CACHE_PATH=/var/lib/project-mai-tai/reference_data.json
MAI_TAI_MARKET_DATA_REFERENCE_CACHE_MAX_AGE_HOURS=24
MAI_TAI_MARKET_DATA_REFERENCE_LOOKBACK_DAYS=20
MAI_TAI_MARKET_DATA_SCAN_MIN_PRICE=1.0
MAI_TAI_MARKET_DATA_SCAN_MAX_PRICE=10.0
MAI_TAI_MARKET_DATA_STATIC_SYMBOLS=
MAI_TAI_MARKET_DATA_WARMUP_ENABLED=true
MAI_TAI_MARKET_DATA_WARMUP_LOOKBACK_DAYS=14
MAI_TAI_MARKET_DATA_WARMUP_BAR_LIMIT=50000
MAI_TAI_MARKET_DATA_LIVE_AGGREGATE_STREAM_ENABLED=false
MAI_TAI_NEWS_ENABLED=true
MAI_TAI_NEWS_SESSION_START_HOUR_ET=16
MAI_TAI_NEWS_CACHE_TTL_MINUTES=15
MAI_TAI_NEWS_REQUEST_TIMEOUT_SECONDS=5
MAI_TAI_NEWS_MAX_ARTICLES_PER_SYMBOL=20
MAI_TAI_NEWS_BATCH_SIZE=5
MAI_TAI_NEWS_PATH_A_MIN_CONFIDENCE=0.85

MAI_TAI_BROKER_DEFAULT_PROVIDER=alpaca
MAI_TAI_OMS_ADAPTER=simulated
MAI_TAI_ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
MAI_TAI_ALPACA_REQUEST_TIMEOUT_SECONDS=10
MAI_TAI_ALPACA_ORDER_FILL_TIMEOUT_SECONDS=10
MAI_TAI_ALPACA_ORDER_POLL_INTERVAL_SECONDS=0.5
MAI_TAI_ALPACA_CANCEL_UNFILLED_AFTER_TIMEOUT=true
MAI_TAI_STRATEGY_MACD_30S_ENABLED=true
MAI_TAI_STRATEGY_WEBULL_30S_ENABLED=false
MAI_TAI_STRATEGY_SCHWAB_1M_ENABLED=false
MAI_TAI_STRATEGY_MACD_30S_PROBE_ENABLED=false
MAI_TAI_STRATEGY_MACD_30S_RECLAIM_ENABLED=false
MAI_TAI_STRATEGY_MACD_30S_RETEST_ENABLED=false
MAI_TAI_STRATEGY_MACD_1M_ENABLED=false
MAI_TAI_STRATEGY_TOS_ENABLED=false
MAI_TAI_STRATEGY_RUNNER_ENABLED=false
MAI_TAI_STRATEGY_MACD_30S_LIVE_AGGREGATE_BARS_ENABLED=false
MAI_TAI_STRATEGY_MACD_30S_LIVE_AGGREGATE_FALLBACK_ENABLED=true
MAI_TAI_STRATEGY_MACD_30S_LIVE_AGGREGATE_STALE_AFTER_SECONDS=3
MAI_TAI_STRATEGY_MACD_30S_TICK_BAR_CLOSE_GRACE_SECONDS=2.0
MAI_TAI_STRATEGY_MACD_30S_TRADE_STREAM_SERVICE=TIMESALE_EQUITY
MAI_TAI_STRATEGY_WEBULL_30S_LIVE_AGGREGATE_BARS_ENABLED=true
MAI_TAI_STRATEGY_WEBULL_30S_LIVE_AGGREGATE_FALLBACK_ENABLED=true
MAI_TAI_STRATEGY_WEBULL_30S_LIVE_AGGREGATE_STALE_AFTER_SECONDS=3
MAI_TAI_STRATEGY_WEBULL_30S_TRADE_STREAM_SERVICE=TIMESALE_EQUITY
MAI_TAI_STRATEGY_MACD_30S_ACCOUNT_NAME=paper:macd_30s
MAI_TAI_STRATEGY_WEBULL_30S_ACCOUNT_NAME=live:webull_30s
MAI_TAI_STRATEGY_WEBULL_30S_BROKER_PROVIDER=webull
MAI_TAI_STRATEGY_MACD_30S_PROBE_ACCOUNT_NAME=paper:macd_30s_probe
MAI_TAI_STRATEGY_MACD_30S_RECLAIM_ACCOUNT_NAME=paper:macd_30s_reclaim
MAI_TAI_STRATEGY_MACD_30S_RETEST_ACCOUNT_NAME=paper:macd_30s_retest
MAI_TAI_STRATEGY_MACD_1M_ACCOUNT_NAME=paper:macd_1m
MAI_TAI_STRATEGY_TOS_ACCOUNT_NAME=paper:tos_runner_shared
MAI_TAI_STRATEGY_RUNNER_ACCOUNT_NAME=paper:tos_runner_shared
MAI_TAI_ALPACA_MACD_30S_API_KEY=REPLACE_ALPACA_30S_API_KEY
MAI_TAI_ALPACA_MACD_30S_SECRET_KEY=REPLACE_ALPACA_30S_SECRET_KEY
MAI_TAI_ALPACA_MACD_1M_API_KEY=REPLACE_ALPACA_1M_API_KEY
MAI_TAI_ALPACA_MACD_1M_SECRET_KEY=REPLACE_ALPACA_1M_SECRET_KEY
MAI_TAI_ALPACA_TOS_RUNNER_API_KEY=REPLACE_ALPACA_TOS_RUNNER_API_KEY
MAI_TAI_ALPACA_TOS_RUNNER_SECRET_KEY=REPLACE_ALPACA_TOS_RUNNER_SECRET_KEY
MAI_TAI_SCHWAB_BASE_URL=https://api.schwabapi.com
MAI_TAI_SCHWAB_TOKEN_URL=https://api.schwabapi.com/v1/oauth/token
MAI_TAI_SCHWAB_REQUEST_TIMEOUT_SECONDS=10
MAI_TAI_SCHWAB_ORDER_FILL_TIMEOUT_SECONDS=10
MAI_TAI_SCHWAB_ORDER_POLL_INTERVAL_SECONDS=0.5
MAI_TAI_SCHWAB_TOKEN_REFRESH_MARGIN_SECONDS=60
MAI_TAI_SCHWAB_ACCESS_TOKEN=
MAI_TAI_SCHWAB_ACCESS_TOKEN_EXPIRES_AT=
MAI_TAI_SCHWAB_REFRESH_TOKEN=
MAI_TAI_SCHWAB_CLIENT_ID=
MAI_TAI_SCHWAB_CLIENT_SECRET=
MAI_TAI_SCHWAB_TOKEN_STORE_PATH=/var/lib/project-mai-tai/schwab_token.json
MAI_TAI_SCHWAB_ACCOUNT_HASH=
MAI_TAI_SCHWAB_MACD_30S_ACCOUNT_HASH=
MAI_TAI_SCHWAB_MACD_1M_ACCOUNT_HASH=
MAI_TAI_SCHWAB_TOS_RUNNER_ACCOUNT_HASH=
MAI_TAI_OMS_BROKER_SYNC_INTERVAL_SECONDS=15

MAI_TAI_DASHBOARD_REFRESH_SECONDS=5
MAI_TAI_SERVICE_HEARTBEAT_INTERVAL_SECONDS=15
MAI_TAI_RECONCILIATION_INTERVAL_SECONDS=30
MAI_TAI_RECONCILIATION_STUCK_ORDER_SECONDS=180
MAI_TAI_RECONCILIATION_STUCK_INTENT_SECONDS=180
MAI_TAI_RECONCILIATION_POSITION_QUANTITY_TOLERANCE=0.0001
MAI_TAI_RECONCILIATION_AVERAGE_PRICE_TOLERANCE=0.02
