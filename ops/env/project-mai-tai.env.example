# Root-owned production environment file for /etc/project-mai-tai/project-mai-tai.env

MAI_TAI_ENVIRONMENT=production
MAI_TAI_LOG_LEVEL=INFO

MAI_TAI_CONTROL_PLANE_HOST=127.0.0.1
MAI_TAI_CONTROL_PLANE_PORT=8100

MAI_TAI_DATABASE_URL=postgresql+psycopg://mai_tai:REPLACE_DB_PASSWORD@localhost:5432/project_mai_tai
MAI_TAI_REDIS_URL=redis://localhost:6379/0
MAI_TAI_REDIS_STREAM_PREFIX=mai_tai

# Optional legacy-side shadow comparison.
MAI_TAI_LEGACY_API_BASE_URL=http://127.0.0.1:8000
MAI_TAI_LEGACY_API_TIMEOUT_SECONDS=3
MAI_TAI_LEGACY_API_CACHE_TTL_SECONDS=5

MAI_TAI_MASSIVE_API_KEY=REPLACE_MASSIVE_API_KEY
MAI_TAI_MARKET_DATA_SNAPSHOT_INTERVAL_SECONDS=30
MAI_TAI_MARKET_DATA_REFERENCE_CACHE_PATH=/var/lib/project-mai-tai/reference_data.json
MAI_TAI_MARKET_DATA_REFERENCE_CACHE_MAX_AGE_HOURS=24
MAI_TAI_MARKET_DATA_REFERENCE_LOOKBACK_DAYS=20
MAI_TAI_MARKET_DATA_SCAN_MIN_PRICE=1.0
MAI_TAI_MARKET_DATA_SCAN_MAX_PRICE=10.0
MAI_TAI_MARKET_DATA_STATIC_SYMBOLS=
MAI_TAI_MARKET_DATA_WARMUP_ENABLED=true
MAI_TAI_MARKET_DATA_WARMUP_LOOKBACK_DAYS=14
MAI_TAI_MARKET_DATA_WARMUP_BAR_LIMIT=50000

MAI_TAI_BROKER_DEFAULT_PROVIDER=alpaca
MAI_TAI_OMS_ADAPTER=simulated
MAI_TAI_ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
MAI_TAI_OMS_BROKER_SYNC_INTERVAL_SECONDS=15

MAI_TAI_DASHBOARD_REFRESH_SECONDS=5
MAI_TAI_SERVICE_HEARTBEAT_INTERVAL_SECONDS=15
MAI_TAI_RECONCILIATION_INTERVAL_SECONDS=30
MAI_TAI_RECONCILIATION_STUCK_ORDER_SECONDS=180
MAI_TAI_RECONCILIATION_STUCK_INTENT_SECONDS=180
MAI_TAI_RECONCILIATION_POSITION_QUANTITY_TOLERANCE=0.0001
MAI_TAI_RECONCILIATION_AVERAGE_PRICE_TOLERANCE=0.02
